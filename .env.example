# ============================================================================
# VARIABLES DE ENTORNO - PLAN ANGÉLICA FLÓREZ
# ============================================================================
# IMPORTANTE: Nunca commits .env al repositorio (solo .env.example)
# Crea tu propio .env en la raíz del proyecto
# ============================================================================

# ============================================================================
# 1. SUPABASE - Base de datos y autenticación
# ============================================================================

# URL de tu proyecto Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co

# Clave anónima de Supabase (PÚBLICA - segura para frontend)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Clave de servicio (PRIVADA - solo para backend/Edge Functions)
# NUNCA la expongas en frontend
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...


# ============================================================================
# 2. OLLAMA - IA local para el chatbot
# ============================================================================

# URL donde corre Ollama (local o remota)
VITE_OLLAMA_API_URL=http://localhost:11434

# Modelo que usa Ollama
# Opciones: qwen3:8b, mistral, neural-chat, etc.
VITE_OLLAMA_MODEL=qwen3:8b

# Timeout para respuestas de Ollama (ms)
VITE_OLLAMA_TIMEOUT=60000


# ============================================================================
# 3. EMAIL - Para envío de reportes
# ============================================================================

# Proveedor SMTP (gmail, outlook, sendgrid, etc.)
VITE_SMTP_HOST=smtp.gmail.com
VITE_SMTP_PORT=587
VITE_SMTP_SECURE=true

# Usuario SMTP
VITE_SMTP_USER=tu-email@gmail.com

# Contraseña de aplicación (NO contraseña del correo)
VITE_SMTP_PASS=app-specific-password-here

# Email de remitente
VITE_SMTP_FROM=noreply@plan-angelica.com

# Email de Angélica para copias
VITE_ADMIN_EMAIL=angelica@example.com


# ============================================================================
# 4. GOOGLE SHEETS - Para exportación de datos
# ============================================================================

# ID de proyecto Google Cloud
VITE_GOOGLE_PROJECT_ID=your-project-id

# API Key de Google Sheets (pública)
VITE_GOOGLE_SHEETS_API_KEY=AIzaSyD...

# ID de la hoja de cálculo (obtén del URL)
VITE_GOOGLE_SHEET_ID=1BxiMVs0...


# ============================================================================
# 5. CONFIGURACIÓN DE LA APLICACIÓN
# ============================================================================

# Ambiente (development, production, staging)
VITE_ENV=development

# URL base de la aplicación
VITE_APP_URL=http://localhost:5173

# Habilitar logging detallado
VITE_DEBUG_MODE=true

# Versión de la aplicación
VITE_APP_VERSION=1.0.0


# ============================================================================
# 6. CLAVES DE ENCRIPTACIÓN (Opcional pero recomendado)
# ============================================================================

# Clave para encriptar datos sensibles en localStorage
VITE_ENCRYPTION_KEY=generate-a-random-key-here

# Salt para hashing
VITE_ENCRYPTION_SALT=random-salt-here


# ============================================================================
# NOTAS IMPORTANTES
# ============================================================================

# ✅ SEGURIDAD:
#   - Todas las variables que empiezan con VITE_ se expondrán al cliente (OK)
#   - Las variables sin VITE_ son solo para backend (NO se exponen)
#   - Clave SERVICE_ROLE nunca debe exponerse al frontend
#   - Las claves de API deben ser rotadas regularmente

# ✅ CÓMO USAR EN JAVASCRIPT:
#   const supabaseUrl = import.meta.env.VITE_SUPABASE_URL
#   const ollamaUrl = import.meta.env.VITE_OLLAMA_API_URL

# ✅ CÓMO GENERAR CLAVES SEGURAS:
#   - Usa: https://1password.com/password-generator/
#   - O genera con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# ✅ CONFIGURACIÓN PARA DIFERENTES AMBIENTES:
#   - .env.local (development - gitignored)
#   - .env.production (production - gitignored)
#   - .env.example (template - tracked in git)
