# ===== SEGURIDAD: NUNCA SUBIR ESTE ARCHIVO AL REPOSITORIO =====
# Copia este archivo a .env.local y reemplaza los valores con los tuyos
# NUNCA pongas claves reales en el código - siempre usa variables de entorno

# ===== OLLAMA (IA Local Gratuita) =====
VITE_OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b
OLLAMA_TIMEOUT=30000

# ===== SUPABASE (Base de datos con RLS) =====
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu_clave_anonima_aqui
SUPABASE_SERVICE_ROLE_KEY=tu_clave_service_aqui

# ===== GOOGLE SHEETS (Para reportes) =====
GOOGLE_SHEETS_API_KEY=tu_clave_google_aqui
GOOGLE_SHEETS_ID=tu_id_hoja_aqui

# ===== EMAIL (Notificaciones) =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_email@gmail.com
SMTP_PASSWORD=tu_contraseña_app
SMTP_FROM=noreply@angelicaflorez.com

# ===== APP SETTINGS =====
APP_ENV=production
APP_DEBUG=false
APP_NAME=Angélica Flórez PRO
APP_VERSION=1.0.0

# ===== NOTES =====
# VITE_ prefix = Frontend variables (públicas pero seguras)
# Sin VITE_ = Backend only (NUNCA exponer al cliente)
# Todos los valores deben estar en .env.local, NUNCA en index-pro-angelica.html
